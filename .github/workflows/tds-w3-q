name: Daily Automated Commit

on:
  schedule:
    # This cron syntax means: run at 14:30 (2:30 PM) UTC every day.
    - cron: '30 14 * * *'
  workflow_dispatch: # This magical line allows you to trigger it manually!

jobs:
  auto-commit:
    runs-on: ubuntu-latest
    permissions:
      contents: write # This gives the robot permission to save changes to your repo

    steps:
      - name: Checkout the repository
        uses: actions/checkout@v4

      - name: Update log for 24f2006360@ds.study.iitm.ac.in
        run: |
          echo "Automated daily run completed on $(date)" >> devsync_log.txt

      - name: Save and push the commit
        run: |
          git config --global user.name "github-actions[bot]"
          git config --global user.email "github-actions[bot]@users.noreply.github.com"
          git add devsync_log.txt
          git commit -m "Automated daily commit"
          git push
